class ArgsHandler(object):

    def __init__(self, handler):
        self.handler = handler

        parser = argparse.ArgumentParser(
            description='apps script control - asctl',
            usage='''./asctl <command> [<args>]

Commands are:
   spreadsheet       Handles spreadsheet actions
   appsscript        Handles appsscript actions
   token             Handles invoice actions
''')
        parser.add_argument('command', help='Subcommand to run')
        # parse_args defaults to [1:] for args, but you need to
        # exclude the rest of the args too, or validation will fail
        args = parser.parse_args(sys.argv[1:2])
        if not hasattr(self, args.command):
            print('Unrecognized command')
            parser.print_help()
            exit(1)
        # use dispatch pattern to invoke method with same name
        getattr(self, args.command)()

    def spreadsheet(self):
        parser = argparse.ArgumentParser(
            description='Spreadsheet actions',
            usage='''./asctl spreadsheet <command> [<args>]

Commands are:
   create     Creates a spreadsheet
''')
        # NOT prefixing the argument with -- means it's not optional
        parser.add_argument('sub')
        args = parser.parse_args(sys.argv[2:3])
        attribute = f'spreadsheet_{args.sub.replace('-', '_')}'
        if not hasattr(self, attribute):
            print('Unrecognized command')
            parser.print_help()
            exit(1)
        getattr(self, attribute)()

    def spreadsheet_create(self):
        spreadsheet_name = os.getenv("SPREADSHEET_NAME")

        parser = argparse.ArgumentParser(description='Creates an spreadsheet')
        parser.add_argument("-n", "--name", required=spreadsheet_name is None, default=spreadsheet_name, help="Name of Spreadsheet", type=str)
        args = parser.parse_args(sys.argv[3:])
        self.handler.create_spreadsheet(vars(args))



    def token(self):
        parser = argparse.ArgumentParser(
            description='Token actions',
            usage='''./asctl token <command> [<args>]

Commands are:
   create     Creates a token
''')
        # NOT prefixing the argument with -- means it's not optional
        parser.add_argument('sub')
        args = parser.parse_args(sys.argv[2:3])
        attribute = f'token_{args.sub.replace('-', '_')}'
        if not hasattr(self, attribute):
            print('Unrecognized command')
            parser.print_help()
            exit(1)
        getattr(self, attribute)()

    def token_create(self):
        parser = argparse.ArgumentParser(description='Creates a token')
        args = parser.parse_args(sys.argv[3:])
        self.handler.create_token(vars(args))

