    def create_version(self, service, script_id, description='v1'):
        """Create a versioned snapshot of the project."""
        version = service.projects().versions().create(
            scriptId=script_id,
            body={'description': description}
        ).execute()
        version_number = version['versionNumber']
        print(f"Created version: {version_number}")
        return version_number

    def deploy(self, service, script_id, version_number):
        """Deploy the script as an API executable."""
        deployment = service.projects().deployments().create(
            scriptId=script_id,
            body={
                'versionNumber': version_number,
                'manifestFileName': 'appsscript',
                'description': 'Deployed via Python'
            }
        ).execute()
        deployment_id = deployment['deploymentId']
        print(f"Deployment ID: {deployment_id}")
        return deployment_id

    def execute_function(self, service, script_id, function_name, parameters=None):
        """Remotely execute a function in the deployed script."""
        request = {
            'function': function_name,
            'parameters': parameters or [],
            'devMode': True   # use latest saved version; set False for prod
        }
        response = service.scripts().run(
            scriptId=script_id,
            body=request
        ).execute()

        if 'error' in response:
            raise RuntimeError(response['error']['details'])

        return response.get('response', {}).get('result')

    def replace_env(self, obj):
        if isinstance(obj, dict):
            return {k: self.replace_env(v) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [self.replace_env(i) for i in obj]
        elif isinstance(obj, str):
            return os.path.expandvars(obj)
        else:
            return obj

