    def share_with_user(self, drive_service, file_id, email, role='writer'):
        """
        role:    'reader' | 'writer' | 'commenter' | 'owner'
        """
        permission = drive_service.permissions().create(
            fileId=file_id,
            sendNotificationEmail=True,
            emailMessage='Here is your spreadsheet access.',
            body={
                'type': 'user',
                'role': role,
                'emailAddress': email
            }
        ).execute()

        print(f"Shared with {email} as {role}. Permission ID: {permission['id']}")
        return permission['id']

    def read_secret(self, creds ,project_id, secret_id, version='latest'):
        client = secretmanager.SecretManagerServiceClient(credentials=creds)

        name = f"projects/{project_id}/secrets/{secret_id}/versions/{version}"
        response = client.access_secret_version(request={"name": name})

        return response.payload.data.decode("utf-8")

