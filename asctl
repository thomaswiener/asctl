TOKEN_JSON = 'token.json'
TOKEN = 'TOKEN'

class Handler():
    def authenticate(self):
        creds = None

        if os.getenv(TOKEN):
            decoded = base64.b64decode(os.getenv(TOKEN)).decode()
            with open(TOKEN_JSON, 'w') as f:
                f.write(decoded)
            creds = Credentials.from_authorized_user_file(TOKEN_JSON, self.get_scopes())

        if not creds or not creds.valid:
            if creds and creds.expired and creds.refresh_token:
                creds.refresh(Request())
            else:
                flow = InstalledAppFlow.from_client_secrets_file(
                    'credentials.json',
                    scopes=self.get_scopes()
                )
                creds = flow.run_local_server(port=0)

                with open(TOKEN, 'w') as f:
                    encoded = base64.b64encode(creds.to_json().encode()).decode()
                    f.write(encoded)

        #print(creds.valid)

        return creds

    def get_scopes(self):
        return [
            'https://www.googleapis.com/auth/script.projects',
            'https://www.googleapis.com/auth/script.deployments',
            'https://www.googleapis.com/auth/drive.file',
            'https://www.googleapis.com/auth/spreadsheets',
            'https://www.googleapis.com/auth/cloud-platform',
        ]

    def create_project(self, service, spreadsheet_id, title='script'):
